// Premium AZ charger/adapter e-commerce platform
// Prisma schema — Neon Postgres

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum Role {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  ACTIVE
  COMING_SOON
  DRAFT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  WHATSAPP
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

enum FaqCategory {
  GENERAL
  SHIPPING
  WARRANTY
  PRODUCT
}

enum WarrantyStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  RESOLVED
}

enum ContactStatus {
  NEW
  READ
  REPLIED
}

// ---------- Core commerce ----------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  phone        String?
  addressLine  String?
  city         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders          Order[]
  reviews         Review[]
  cart            Cart?
  warrantyClaims  WarrantyClaim[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Product {
  id                String        @id @default(cuid())
  name              String
  slug              String        @unique
  shortDescription  String
  story             String
  price             Decimal       @db.Decimal(10, 2)
  compareAtPrice    Decimal?      @db.Decimal(10, 2)
  sku               String        @unique
  stock             Int           @default(0)
  wattage           Int
  cableType         String
  connectorType     String
  whatsInBox        String[]
  warrantyMonths    Int           @default(24)
  status            ProductStatus @default(ACTIVE)
  featured          Boolean       @default(false)
  isDemo            Boolean       @default(false)
  metaTitle         String?
  metaDescription   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images              ProductImage[]
  variants            ProductVariant[]
  reviews             Review[]
  compatibilityRules  CompatibilityRule[]
  orderItems          OrderItem[]
  cartItems           CartItem[]

  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  data      Bytes
  mimeType  String
  alt       String
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String
  sku           String   @unique
  priceOverride Decimal? @db.Decimal(10, 2)
  stock         Int      @default(0)
  attributes    Json

  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod

  subtotal Decimal @db.Decimal(10, 2)
  shipping Decimal @db.Decimal(10, 2) @default(0)
  total    Decimal @db.Decimal(10, 2)
  currency String  @default("AZN")

  customerName  String
  customerPhone String
  customerEmail String?
  city          String
  addressLine   String
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([userId])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  nameSnapshot String
  priceSnapshot Decimal @db.Decimal(10, 2)
  quantity     Int
  subtotal     Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  sessionId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int             @default(1)

  @@index([cartId])
}

model Review {
  id               String       @id @default(cuid())
  productId        String
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?        @relation(fields: [userId], references: [id])
  authorName       String
  rating           Int
  title            String
  body             String
  verifiedPurchase Boolean      @default(false)
  status           ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())

  @@index([productId])
}

model BlogPost {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String
  content         String
  coverImageData  Bytes?
  coverImageMime  String?
  tags            String[]
  status          BlogStatus @default(DRAFT)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model FAQ {
  id        String      @id @default(cuid())
  question  String
  answer    String
  category  FaqCategory @default(GENERAL)
  order     Int         @default(0)
  published Boolean     @default(true)
}

model WarrantyClaim {
  id              String         @id @default(cuid())
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  orderId         String?
  productId       String?
  name            String
  email           String
  phone           String
  issueDescription String
  status          WarrantyStatus @default(PENDING)
  adminNotes      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
}

// ---------- Compatibility checker ----------

model PhoneBrand {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  order Int    @default(0)

  models PhoneModel[]
}

model PhoneModel {
  id                String     @id @default(cuid())
  brandId           String
  brand             PhoneBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name              String
  slug              String     @unique
  releaseYear       Int?
  batteryCapacityMah Int?

  compatibilityRules CompatibilityRule[]

  @@index([brandId])
}

model CompatibilityRule {
  id                    String   @id @default(cuid())
  phoneModelId          String
  phoneModel            PhoneModel @relation(fields: [phoneModelId], references: [id], onDelete: Cascade)
  recommendedProductId  String?
  recommendedProduct    Product? @relation(fields: [recommendedProductId], references: [id])
  maxWattage            Int
  cableType             String
  connectorType         String
  estimatedChargeMinutes Int
  compatibilityScore    Int
  notes                 String?

  @@index([phoneModelId])
  @@index([recommendedProductId])
}

// ---------- Misc ----------

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)
}

model AdminSetting {
  id          String @id @default(cuid())
  key         String @unique
  value       Json
  description String?
}
